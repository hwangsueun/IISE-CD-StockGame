# PostgreSQL 접속 (docker-compose 기본값)
DATABASE_URL=postgresql://admin:password@localhost:5432/antsurvival
PORT=3001
CORS_ORIGIN=http://localhost:5173

# 게임 시작일 선택 범위 (240거래일이 범위 안에 들어가도록 서버가 상한 보정)
GAME_START_RANGE=2013-01-02..2023-12-31

# 시드 데이터 원천 루트 (data-pipeline 체크아웃 위치 또는 Drive 다운로드 폴더)
DATA_DIR=/Users/hgs/Desktop/IISE-CD/data-pipeline
